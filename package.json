{
   "name": "KogarBE",
   "version": "1.0.0",
   "description": "",
   "scripts": {
      "build": "nest build",
      "start": "nest start",
      "start:dev": "nest start --watch",
      "start:debug": "nest start --debug --watch",
      "start:prod": "node dist/main",
      "typeorm": "typeorm-ts-node-commonjs",
      "makemigration": "typeorm-ts-node-commonjs migration:generate -d ./src/data-source.ts src/migrations/migrations",
      "migrate": "npm run build && typeorm-ts-node-commonjs migration:run -d ./src/data-source.ts",
      "revert": "typeorm-ts-node-commonjs migration:revert -d ./src/data-source.ts",
      "schema:drop": "npm run build && typeorm-ts-node-commonjs schema:drop -d ./src/data-source.ts"
   },
   "dependencies": {
      "@nestjs/common": "^11.1.27",
      "@nestjs/core": "^11.1.27",
      "@nestjs/jwt": "^11.0.2",
      "@nestjs/platform-express": "^11.1.27",
      "@nestjs/typeorm": "^11.0.2",
      "class-transformer": "^0.5.1",
      "cookie-parser": "^1.4.7",
      "dotenv": "^17.4.2",
      "pg": "^8.22.0",
      "reflect-metadata": "^0.2.2",
      "rxjs": "^7.8.2",
      "typeorm": "1.0.0"
   },
   "devDependencies": {
      "@nestjs/cli": "^11.0.23",
      "@nestjs/schematics": "^11.1.0",
      "@types/cookie-parser": "^1.4.10",
      "@types/express": "^5.0.6",
      "@types/node": "^20.19.40",
      "ts-loader": "^9.6.2",
      "ts-node": "^10.9.2",
      "typescript": "^5.5.3"
   },
   "private": true
}
